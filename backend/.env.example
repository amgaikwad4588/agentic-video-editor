# Copy to .env and fill in. Everything has a working default except the key.

# Agent chat needs ONE of these keys; the rest of the editor works without.
# Anthropic is preferred when both are set; force with AGENT_PROVIDER.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional overrides
# AGENT_PROVIDER=gemini            # or anthropic
# AGENT_MODEL=claude-opus-4-8
# GEMINI_MODEL=gemini-2.5-flash
# AGENT_MAX_ITERATIONS=12
# DATA_DIR=./data
# FFMPEG_PATH=
# FONT_PATH=
# MAX_UPLOAD_MB=1024
